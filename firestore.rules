rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: check if user is admin
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }


    // Users collection
    match /users/{userId} {
      // Anyone can read public profiles
      allow read: if true;

      // Users can create their own profile
      allow create: if isAuth() && request.auth.uid == userId;

      // Users can update their own non-role fields
      // Only admins can change roles
      allow update: if isAuth() && request.auth.uid == userId && (
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
      );
      // Admins can update any field including role
      allow update: if isAdmin();

      // Only admins can delete users
      allow delete: if isAdmin();

      // Dados sensíveis (CPF/CNPJ e endereço completo) ficam fora do
      // documento público, legíveis apenas pelo dono e por admins.
      // Path restrito ao documento único "profile" para evitar a criação
      // de documentos arbitrários na subcoleção.
      match /private/profile {
        allow read: if isAuth() && (request.auth.uid == userId || isAdmin());
        allow write: if isAuth() && request.auth.uid == userId;
      }
    }

    // Products collection
    match /products/{productId} {
      // Anyone can read approved, active or pending products. Owners can read their own products.
      allow read: if resource.data.status == 'approved' 
                  || resource.data.status == 'active' 
                  || resource.data.status == 'pending' 
                  || (isAuth() && resource.data.userId == request.auth.uid) 
                  || isAdmin();

      // Authenticated users can create products
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;

      // Sellers can update their own products
      // Admins can update any product (moderation)
      allow update: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );

      // Sellers can soft-delete
      // Admins can delete any product
      allow delete: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
    }

    // Luthiers collection
    match /luthiers/{luthierId} {
      // Anyone can read luthier profiles
      allow read: if true;

      // Only authenticated luthiers can create their profile
      allow create: if isAuth() && request.auth.uid == luthierId;

      // Luthiers can update their own profile
      allow update: if isAuth() && request.auth.uid == luthierId;

      allow delete: if isAdmin();
    }

    // Teachers collection
    match /teachers/{teacherId} {
      // Anyone can read teacher profiles
      allow read: if true;

      // Only authenticated teachers can create their profile
      allow create: if isAuth() && request.auth.uid == teacherId;

      // Teachers can update their own profile
      allow update: if isAuth() && request.auth.uid == teacherId;

      allow delete: if isAdmin();
    }

    // Appointments collection
    match /appointments/{appointmentId} {
      // Users can read their own appointments (as client or luthier)
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        resource.data.luthierId == request.auth.uid ||
        isAdmin()
      );

      // Authenticated users can create appointments
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;

      // Clients or luthiers can update their appointments
      allow update: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        resource.data.luthierId == request.auth.uid
      );

      allow delete: if isAdmin();
    }

    // Chats collection
    match /chats/{chatId} {
      // Only participants can read the chat (allow read if doc doesn't exist yet for getDoc checks)
      allow read: if isAuth() && (resource == null || request.auth.uid in resource.data.participants);

      // Authenticated users can create chats
      allow create: if isAuth() && request.auth.uid in request.resource.data.participants;

      // Participants can update the chat
      allow update: if isAuth() && request.auth.uid in resource.data.participants;

      allow delete: if false;

      // Messages subcollection
      match /messages/{messageId} {
        // Only chat participants can read messages
        allow read: if isAuth() && get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);

        // Participants can send messages (com limite de tamanho contra abuso)
        allow create: if isAuth() &&
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.text is string &&
          request.resource.data.text.size() <= 2000 &&
          get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);

        allow update, delete: if false;
      }
    }

    // Proposals collection
    match /proposals/{proposalId} {
      // Sender or receiver can read the proposal
      allow read: if isAuth() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid ||
        isAdmin()
      );

      // Authenticated users can create proposals
      allow create: if isAuth() && request.resource.data.senderId == request.auth.uid;

      // Sender or receiver can update proposal status
      allow update: if isAuth() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid
      );

      allow delete: if false;
    }

    // Favorites collection
    match /favorites/{favoriteId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && request.auth.uid == resource.data.userId;
    }

    // Ratings subcollection (under products)
    match /products/{productId}/ratings/{ratingId} {
      // Anyone can read ratings
      allow read: if true;

      // Authenticated users can create ratings (but not their own product)
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.sellerId != request.auth.uid;

      // Users can update their own rating
      allow update: if isAuth() && resource.data.userId == request.auth.uid;

      // Only admins can delete ratings
      allow delete: if isAdmin();
    }

    // Top-level Profile Ratings collection
    match /ratings/{ratingId} {
      // Anyone can read ratings
      allow read: if true;

      // Authenticated users can create ratings (but not for themselves)
      // Must be linked to an accepted proposal (concluded sale)
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.sellerId != request.auth.uid
        && request.resource.data.proposalId is string
        && get(/databases/$(database)/documents/proposals/$(request.resource.data.proposalId)).data.status == 'accepted'
        && get(/databases/$(database)/documents/proposals/$(request.resource.data.proposalId)).data.sellerId == request.resource.data.sellerId
        && get(/databases/$(database)/documents/proposals/$(request.resource.data.proposalId)).data.receiverId == request.auth.uid;

      // Only admins can update (approve/reject) or delete profile ratings
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Verifications collection
    match /verifications/{verificationId} {
      // Users can read their own verification
      // Admins can read all verifications
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );

      // Authenticated users can create their own verification request
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;

      // Only admins can update verification status
      allow update: if isAdmin();

      allow delete: if false;
    }

    // Banners collection (carrossel da home). Sem esta regra o catch-all
    // nega a leitura e o BannerCarousel sempre cai no fallback local.
    match /banners/{bannerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ==========================================
    // Social: Posts collection
    // ==========================================
    match /posts/{postId} {
      // Posts are public
      allow read: if true;

      // Authenticated users can create posts (userId must match)
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid;

      // Post owner can update any field; any auth user can update only reactions
      allow update: if isAuth()
        && (resource.data.userId == request.auth.uid
            || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'totalReactions']));

      // Post owner or admin can delete
      allow delete: if isAuth()
        && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ==========================================
    // Social: User Favorites (follow profiles)
    // ==========================================
    match /userFavorites/{favId} {
      // Any authenticated user can read favorites
      allow read: if isAuth();

      // Users can create their own follow entries
      allow create: if isAuth()
        && request.resource.data.followerId == request.auth.uid;

      // Followers can only toggle notifyEnabled
      allow update: if isAuth()
        && resource.data.followerId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['notifyEnabled']);

      // Followers can unfollow
      allow delete: if isAuth()
        && resource.data.followerId == request.auth.uid;
    }

    // Notifications collection
    match /notifications/{notificationId} {
      // Users can read their own notifications
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      // Authenticated users can create notifications (e.g. when favoriting).
      // Valida o formato para limitar abuso (payloads gigantes / tipos arbitrários).
      allow create: if isAuth()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.userId is string
        && request.resource.data.type in ['favorite', 'proposal', 'rating', 'system', 'new_post', 'new_follower']
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 200
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 1000
        && request.resource.data.read == false;
      // Users can update (read/unread) and delete their own notifications
      allow update, delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

