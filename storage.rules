rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Product images
    match /products/{productId}/{imageId} {
      // Anyone can read product images
      allow read: if true;

      // Only authenticated users who own the product can upload
      // Allow create if user is authenticated
      allow create: if request.auth != null;

      // Owner can update/delete
      allow update, delete: if request.auth != null
        && request.auth.uid == firestore.get(/databases/(default)/documents/products/$(productId)).data.sellerId;
    }

    // User avatars
    match /avatars/{userId}/{fileName} {
      // Anyone can read avatars
      allow read: if true;

      // Only the user can upload their avatar
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Luthier portfolio images
    match /portfolios/{luthierId}/{portfolioId}/{fileName} {
      // Anyone can read portfolio images
      allow read: if true;

      // Only the luthier can upload portfolio images
      allow write: if request.auth != null && request.auth.uid == luthierId;
    }

    // Chat images
    match /chats/{chatId}/{messageId}/{fileName} {
      // Only chat participants can read
      allow read: if request.auth != null
        && firestore.get(/databases/(default)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);

      // Participants can upload images
      allow create: if request.auth != null
        && firestore.get(/databases/(default)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);

      allow update, delete: if false;
    }

    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
