rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ==========================================
    // Helper Functions
    // ==========================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.admin == true ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
    
    // Validates if the file is an image and stays below a maximum size limit (in MB)
    function isValidImage(maxSizeMB) {
      return request.resource.contentType.matches('image/.*') 
             && request.resource.size < maxSizeMB * 1024 * 1024;
    }

    // ==========================================
    // Path-specific Rules (Marketplace)
    // ==========================================

    // Product images
    match /products/{productId}/{imageId} {
      // Anyone can read product images
      allow read: if true;

      // Only authenticated users can upload product images (validated size & type)
      allow create: if isAuthenticated() && isValidImage(10);

      // Only the product seller (owner) or an admin can update or delete product images.
      // Product documents store the owner under "userId" (see ProductData in src/lib/roles.ts).
      allow update, delete: if isAdmin() || (
        isAuthenticated() &&
        request.auth.uid == firestore.get(/databases/(default)/documents/products/$(productId)).data.userId
      );
    }

    // User avatars
    match /avatars/{userId}/{fileName} {
      // Anyone can read avatars
      allow read: if true;

      // Only the user or an admin can upload/update/delete their avatar
      allow write: if isAdmin() || (isAuthenticated() && request.auth.uid == userId && isValidImage(5));
    }

    // Luthier portfolio images
    match /portfolios/{luthierId}/{portfolioId}/{fileName} {
      // Anyone can read portfolio images
      allow read: if true;

      // Only the luthier or an admin can upload portfolio images
      allow write: if isAdmin() || (isAuthenticated() && request.auth.uid == luthierId && isValidImage(10));
    }

    // Chat images
    match /chats/{chatId}/{messageId}/{fileName} {
      // Only chat participants or admins can read
      allow read: if isAdmin() || (
        isAuthenticated() && 
        firestore.get(/databases/(default)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid])
      );

      // Only chat participants can upload images to the chat
      allow create: if isAuthenticated() && 
        firestore.get(/databases/(default)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]) &&
        isValidImage(10);

      // Deletes and updates are disabled for security/integrity
      allow update, delete: if isAdmin();
    }

    // Verification documents (ID + selfie)
    match /verifications/{userId}/{fileName} {
      // Only the user and admins can read verification documents
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);

      // Only the user can upload verification documents
      allow create: if isAuthenticated() && request.auth.uid == userId && isValidImage(10);

      // Only admins can delete
      allow delete: if isAdmin();
    }

    // ==========================================
    // Social: Post images
    // ==========================================
    match /social/{userId}/{postId}/{fileName} {
      // Anyone can view social post images
      allow read: if true;

      // Only the post owner can upload images (5MB max)
      allow write: if isAuthenticated() && request.auth.uid == userId && isValidImage(5);
    }

    // ==========================================
    // Social: Equipment images
    // ==========================================
    match /equipment/{userId}/{fileName} {
      // Anyone can view equipment images
      allow read: if true;

      // Only the equipment owner can upload images (5MB max)
      allow write: if isAuthenticated() && request.auth.uid == userId && isValidImage(5);
    }

    // ==========================================
    // Trade proposal images (FIX: regra em falta)
    // ==========================================
    match /proposals/{receiverId}/{fileName} {
      // Authenticated users can read proposal images
      allow read: if isAuthenticated();

      // Authenticated users can upload proposal images (10MB max)
      allow create: if isAuthenticated() && isValidImage(10);

      // Only admin can update/delete
      allow update, delete: if isAdmin();
    }

    // Deny all other access by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
